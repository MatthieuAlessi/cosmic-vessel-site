---
type Code = 'tl' | 'tr' | 'bl' | 'br';

interface Props {
  size?: number;
  class?: string;
  corner?:
    | 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right'
    | 'top' | 'bottom' | 'left' | 'right' | 'all';
}
const { size = 36, class: className = '', corner = 'all' } = Astro.props;

// Quels coins afficher selon le prop
const groups: Record<NonNullable<Props['corner']>, Code[]> = {
  'all':          ['tl', 'tr', 'bl', 'br'],
  'top':          ['tl', 'tr'],
  'bottom':       ['bl', 'br'],
  'left':         ['tl', 'bl'],
  'right':        ['tr', 'br'],
  'top-left':     ['tl'],
  'top-right':    ['tr'],
  'bottom-left':  ['bl'],
  'bottom-right': ['br'],
};
const corners = groups[corner] ?? groups.all;

// Définition de chaque coin (position + arc + petit cercle d'angle)
const defs: Record<Code, { pos: string; path: string; cx: number; cy: number }> = {
  tl: { pos: 'top-0 left-0',     path: 'M 32,0 A 32,32 0 0 0 0,32', cx: 6,  cy: 6  },
  tr: { pos: 'top-0 right-0',    path: 'M 4,0 A 32,32 0 0 1 36,32', cx: 30, cy: 6  },
  bl: { pos: 'bottom-0 left-0',  path: 'M 0,4 A 32,32 0 0 0 32,36', cx: 6,  cy: 30 },
  br: { pos: 'bottom-0 right-0', path: 'M 36,4 A 32,32 0 0 1 4,36', cx: 30, cy: 30 },
};
---

{corners.map((c) => {
  const d = defs[c];
  return (
    <svg viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg" fill="none"
      class:list={['absolute', d.pos, className]}
      style={`width:${size}px;height:${size}px;`}>
      <path d={d.path} stroke="var(--color-primary-700)" stroke-width="1" opacity="0.9" />
      <circle cx={d.cx} cy={d.cy} r="2.5" stroke="var(--color-primary-500)" stroke-width="0.75" opacity="0.9" />
      <circle cx="18" cy="18" r="1.8" fill="var(--color-primary-500)" opacity="1" />
    </svg>
  );
})}
