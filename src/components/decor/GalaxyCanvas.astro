---
interface Props {
  maskClass?: string;
  opacity?: number;
  count?: number;
  class?: string;
  fixed?: boolean;
}
const { maskClass = '', opacity = 0.85, count = 90, class: className = '', fixed = false } = Astro.props;
const uid = `gc-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  class:list={[fixed ? 'fixed' : 'absolute', 'inset-0 pointer-events-none', maskClass, className]}
  style={`opacity: ${opacity}`}
>
  <canvas class="w-full h-full block"></canvas>
</div>

<script define:vars={{ uid, count, fixed }}>
  const wrapper = document.getElementById(uid);
  const canvas  = wrapper.querySelector('canvas');
  const ctx     = canvas.getContext('2d');

  let W, H, stars = [];
  let rafId = null;
  let active = true;

  function resize() {
    W = canvas.width  = fixed ? window.innerWidth  : wrapper.offsetWidth;
    H = canvas.height = fixed ? window.innerHeight : wrapper.offsetHeight;
  }

  // Tout ce qui est constant est pré-calculé à la création — zéro calcul répété en hot loop
  function makeStar() {
    const z = 0.05 + Math.random() * 0.95;
    const r = (180 + z * 75) | 0;
    const b = (210 + z * 45) | 0;
    return {
      x:          Math.random() * W,
      y:          Math.random() * H,
      phase:      Math.random() * Math.PI * 2,
      color:      `rgb(${r},205,${b})`,   // string pré-baked, jamais recréée
      baseAlpha:  0.06 + z * 0.85,
      size:       0.15 + z * 0.85,
      drift:      0.04 * z,               // vitesse horizontale pré-calculée
      phaseSpeed: 0.008 + z * 0.005,
    };
  }

  function init() {
    resize();
    stars = Array.from({ length: count }, makeStar);
  }

  /* ── étoiles filantes ── */
  const shootings = [];
  function spawnShooting() {
    if (shootings.length >= 2) return;
    shootings.push({
      x: Math.random() * W * 0.6,
      y: Math.random() * H * 0.5,
      vx: 4 + Math.random() * 4,
      vy: 2 + Math.random() * 2.5,
      life: 1,
    });
  }
  function scheduleShooting() {
    spawnShooting();
    setTimeout(scheduleShooting, 3000 + Math.random() * 5000);
  }

  /* ── boucle de rendu ── */
  function draw() {
    rafId = requestAnimationFrame(draw);

    ctx.clearRect(0, 0, W, H);

    // Stars : globalAlpha évite toute création de string rgba
    for (const s of stars) {
      s.phase += s.phaseSpeed;
      s.x     += s.drift;
      if (s.x > W) { s.x = 0; s.y = Math.random() * H; }

      ctx.globalAlpha = s.baseAlpha * (0.4 + 0.6 * Math.sin(s.phase));
      ctx.fillStyle   = s.color;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
      ctx.fill();
    }

    // Étoiles filantes
    ctx.globalAlpha = 1;
    for (let i = shootings.length - 1; i >= 0; i--) {
      const sh = shootings[i];
      sh.x    += sh.vx;
      sh.y    += sh.vy;
      sh.life -= 0.022;

      if (sh.life <= 0 || sh.x > W || sh.y > H) {
        shootings.splice(i, 1);
        continue;
      }

      const tx = sh.x - sh.vx * 16;
      const ty = sh.y - sh.vy * 16;
      const g  = ctx.createLinearGradient(tx, ty, sh.x, sh.y);
      g.addColorStop(0, 'rgba(255,240,200,0)');
      g.addColorStop(1, `rgba(255,240,200,${(sh.life * 0.9).toFixed(2)})`);
      ctx.strokeStyle = g;
      ctx.lineWidth   = 1.5;
      ctx.beginPath();
      ctx.moveTo(tx, ty);
      ctx.lineTo(sh.x, sh.y);
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(sh.x, sh.y, 1.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,220,${sh.life.toFixed(2)})`;
      ctx.fill();
    }

    ctx.globalAlpha = 1;
  }

  // Pause quand l'onglet est caché
  document.addEventListener('visibilitychange', () => {
    active = !document.hidden;
    if (active && !rafId) rafId = requestAnimationFrame(draw);
    if (!active && rafId) { cancelAnimationFrame(rafId); rafId = null; }
  });

  new ResizeObserver(resize).observe(wrapper);
  init();
  scheduleShooting();
  rafId = requestAnimationFrame(draw);
</script>
