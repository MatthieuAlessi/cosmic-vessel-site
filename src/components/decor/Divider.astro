---
interface Props {
  /** Position verticale du trait dans son parent (qui doit être `relative`). */
  position?: 'top' | 'bottom' | 'unset';
  /** Largeur Tailwind (défaut pleine largeur). */
  width?: string;
  /** true = dégradé doré qui s'estompe sur les côtés (comme l'ancien `.line`). false = trait plein doré. */
  gradient?: boolean;
  /** Opacité du trait. */
  opacity?: number;
  class?: string;
}

const {
  position = 'bottom',
  width = 'w-full',
  gradient = true,
  opacity = 0.5,
  class: className = '',
} = Astro.props;

const positionClass: Record<'top' | 'bottom' | 'unset', string> = {
  top: 'top-0',
  bottom: 'bottom-0',
  unset: ' ',
};

// Dégradé doré verrouillé (non configurable) — reprend exactement l'ancien `.line`.
const background = gradient
  ? 'linear-gradient(90deg, transparent, var(--color-primary-500) 30%, var(--color-primary) 50%, var(--color-primary-500) 70%, transparent)'
  : 'var(--color-primary)';
---

<div
  class:list={['absolute left-0 h-px z-10', positionClass[position], width, className]}
  style={`background:${background};opacity:${opacity}`}
></div>
