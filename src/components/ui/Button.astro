---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'ghost-white';
  size?: 'xs' | 'sm' | 'md' | 'lg';
  href?: string;
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  transform?: 'uppercase' | 'capitalize';
}

const {
  variant = 'primary',
  size = 'sm',
  href,
  disabled = false,
  type = 'button',
  class: className,
  transform,
} = Astro.props;

const Tag = href ? 'a' : 'button';

const sizeClasses = {
  xs: 'py-1 px-3 text-xs ',
  sm: 'py-2 px-5 text-sm ',
  md: 'py-3 px-8 text-sm ',
  lg: 'py-4 px-10 text-base ',
}[size];
---

<Tag
  class:list={['btn', `btn--${variant}`, sizeClasses, className, transform]}
  href={href}
  disabled={!href ? disabled : undefined}
  aria-disabled={href && disabled ? 'true' : undefined}
  type={!href ? type : undefined}
>
  <slot />
</Tag>
