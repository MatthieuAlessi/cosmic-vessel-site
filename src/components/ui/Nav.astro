---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/character', label: 'Character' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/team', label: 'Team' },
  { href: '/blog', label: 'News' },
  { href: '/contact', label: 'Contact' },
];

import Button from '@components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import CornerOrnament from '@components/decor/CornerOrnament.astro';

const currentPath = Astro.url.pathname;
---

<nav class="nav border-panel border border-white/10" id="main-nav">

 <CornerOrnament size={34} corner="top-left" tone="white" class="opacity-20" />
  <CornerOrnament size={34} corner="top-right" tone="white" class="opacity-20" />

  <div class="grid grid-cols-3 items-center w-full px-8">

    <!-- Logo -->
    <a href="/" class="nav__logo">[MOD NAME]</a>

    <!-- Liens centrés -->
    <ul class="nav__links justify-center">
      {navLinks.map(link => (
        <li class=" ">
          <a
            href={link.href}
            class:list={['nav__link', { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="flex justify-end">
      <Button href="/blog" variant="ghost-white" size="xs">Follow Dev</Button>
    </div>

  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
