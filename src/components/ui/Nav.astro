---
// Nav adaptée d'un modèle Tailwind Plus (structure burger-gauche + disclosure),
// restylée avec la charte du site et débarrassée de `@tailwindplus/elements`
// (toggle en vanilla JS). Bascule en burger sous `lg` (tablette + téléphone).
import { navLinks } from '@data/navigation';
import Button from '@components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import CornerOrnament from '@components/decor/CornerOrnament.astro';

const currentPath = Astro.url.pathname;
---

<nav class="nav border-panel border border-white/10 bg-background-500 lg:bg-transparent lg:[&.is-scrolled]:bg-background/40 lg:[&.is-scrolled]:backdrop-blur-sm" id="main-nav">

  <CornerOrnament size={34} corner="top-left" tone="white" class="opacity-20" />
  <CornerOrnament size={34} corner="top-right" tone="white" class="opacity-20" />

  <div class="w-full px-4 sm:px-6 lg:px-8">
    <div class="relative flex h-12 lg:h-12 items-center justify-between">

      <!-- Burger (tablette + téléphone), calé à droite -->
      <div class="absolute inset-y-0 right-0 flex items-center lg:hidden">
        <button
          type="button"
          data-nav-toggle
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="inline-flex items-center justify-center rounded-md p-2 -mr-2 text-foreground-300 hover:bg-white/5 hover:text-white transition-colors"
        >
          <span class="sr-only">Open main menu</span>
          <Icon name="ph:list" class="icon-menu w-6 h-6" />
          <Icon name="ph:x" class="icon-close w-6 h-6 hidden" />
        </button>
      </div>

      <!-- Logo : centré en mobile, à gauche en desktop -->
      <div class="flex flex-1 items-center justify-center lg:justify-start min-w-0">
        <a href="/" class="nav__logo shrink-0">[MOD NAME]</a>
      </div>

      <!-- Liens centrés (desktop) — entre deux sections flex-1 égales -->
      <ul class="hidden lg:flex items-center gap-x-6 shrink-0">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav__link', { active: currentPath === link.href }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA (droite, desktop) — section flex-1 = côté droit, symétrique au logo -->
      <div class="hidden lg:flex flex-1 items-center justify-end gap-2">
        <button type="button" data-trailer-open class="btn btn--ghost-white py-1 px-3  lg:py-2 lg:px-4 text-xs lg:text-sm  ">
          <Icon name="ph:play" class="w-4 h-4" />
          Watch Trailer
        </button>
        <Button href="/blog" variant="ghost-white"  >Follow Dev</Button>
      </div>

    </div>
  </div>

  <!-- Panneau mobile (déroulant sous la barre) -->
  <div
    id="mobile-menu"
    data-nav-panel
    class="lg:hidden absolute top-full inset-x-0 mt-2 border-panel border border-white/10 bg-background-500/95 backdrop-blur-md shadow-xl opacity-0 -translate-y-2 pointer-events-none transition-all duration-300 data-open:opacity-100 data-open:translate-y-0 data-open:pointer-events-auto"
  >
    <div class="space-y-1 px-3 pt-3 pb-2">
      {navLinks.map(link => (
        <a
          href={link.href}
          aria-current={currentPath === link.href ? 'page' : undefined}
          class:list={[
            'block rounded-md px-3 py-2 font-ui text-base transition-colors',
            currentPath === link.href
              ? 'bg-white/5 text-white'
              : 'text-foreground-300 hover:bg-white/5 hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex flex-col gap-2 px-3 pt-3 pb-4 mt-1 border-t border-white/10">
      <button type="button" data-trailer-open class="btn btn--ghost-white py-2 px-3 text-xs justify-center">
        <Icon name="ph:play" class="w-4 h-4" />
        Watch Trailer
      </button>
      <Button href="/blog" variant="ghost-white" size="sm">Follow Dev</Button>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  if (nav) {
    // Fond intensifié au scroll (inchangé)
    const onScroll = () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Menu burger (vanilla — remplace @tailwindplus/elements)
    const toggle = nav.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    const panel = nav.querySelector<HTMLElement>('[data-nav-panel]');
    const iconMenu = toggle?.querySelector('.icon-menu');
    const iconClose = toggle?.querySelector('.icon-close');

    if (toggle && panel) {
      const setOpen = (open: boolean) => {
        panel.toggleAttribute('data-open', open);
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        iconMenu?.classList.toggle('hidden', open);
        iconClose?.classList.toggle('hidden', !open);
      };

      toggle.addEventListener('click', () => setOpen(!panel.hasAttribute('data-open')));

      // Fermeture : clic sur un lien, touche Échap, clic en dehors de la nav
      panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setOpen(false);
      });
      document.addEventListener('click', (e) => {
        if (panel.hasAttribute('data-open') && !nav.contains(e.target as Node)) setOpen(false);
      });
    }
  }
</script>
