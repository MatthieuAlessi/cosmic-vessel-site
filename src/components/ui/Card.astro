---
import Button from "@components/ui/Button.astro"

interface Props {
  variant?: "article" | "horizontal"
  cta?: string
  href?: string
  class?: string
}

const { variant = "article", cta, href, class: className = "" } = Astro.props

const classes = [
  "bg-background-300",
  "border-panel",
  "border",
  "border-primary-500/20",
  "shadow-xl",
  "overflow-hidden",
  className,
]
  .filter(Boolean)
  .join(" ")

// Zoom léger de l'image au hover (comme la galerie), via la variante Tailwind
// "*" (enfants directs) — appliqué au conteneur, pas besoin de toucher les
// <img slot="image"> des appelants. Nécessite "group" sur l'<article>.
const imgZoomClasses =
  "overflow-hidden *:transition-transform *:duration-500 group-hover:*:scale-105"
---

{
  variant === "article" && (
    <article class={`group ${classes}  `}>
      {href ? (
        <a
          href={href}
          tabindex="-1"
          aria-hidden="true"
          class={`block aspect-video ${imgZoomClasses}`}
        >
          <slot name="image" />
        </a>
      ) : (
        <div class={`aspect-video ${imgZoomClasses}`}>
          <slot name="image" />
        </div>
      )}
      <div class="p-4 flex flex-col ">
        <div class="flex flex-col justify-between h-full">
          <div class="flex gap-1 mb-3">
            <slot name="badge" />
          </div>
          <h3 class=" text-base font-body text-foreground-300 mb-2">
            {href ? (
              <a href={href} class="hover:text-primary-100 transition-colors duration-300">
                <slot name="title" />
              </a>
            ) : (
              <slot name="title" />
            )}
          </h3>
          <p class="text-foreground-500 text-xs leading-relaxed">
            <slot name="excerpt" />
          </p>
        </div>

        <div class="flex items-center justify-between pt-4 mt-auto">
          <div class="flex items-center gap-2 text-2xs font-ui   text-foreground-500/50  ">
            <slot name="meta" />
          </div>
          {cta && (
            <Button variant="ghost" size="xs" href={href}>
              {cta}
            </Button>
          )}
        </div>
      </div>
    </article>
  )
}

{
  variant === "horizontal" && (
    <article class={`group ${classes} flex flex-col sm:flex-row`}>
      {href ? (
        <a
          href={href}
          tabindex="-1"
          aria-hidden="true"
          class={`  aspect-video   sm:w-1/3 shrink-0 ${imgZoomClasses}`}
        >
          <slot name="image" />
        </a>
      ) : (
        <div class={`aspect-video     shrink-0 ${imgZoomClasses}`}>
          <slot name="image" />
        </div>
      )}
      <div class="p-4 sm:p-8 flex flex-col flex-1">
        <div class="flex flex-col justify-between h-full">
          <div class="flex gap-1 mb-3">
            <slot name="badge" />
          </div>
          <h3 class=" text-base font-body text-foreground-300 mb-2">
            {href ? (
              <a href={href} class="hover:text-primary-100 transition-colors duration-300">
                <slot name="title" />
              </a>
            ) : (
              <slot name="title" />
            )}
          </h3>
          <p class="text-foreground-500 text-xs leading-relaxed">
            <slot name="excerpt" />
          </p>
        </div>

        <div class="flex items-center justify-between pt-4 mt-auto">
          <div class="flex items-center gap-2 text-2xs font-ui  text-foreground-500/50  ">
            <slot name="meta" />
          </div>
          {cta && (
            <Button variant="ghost" size="xs" href={href}>
              {cta}
            </Button>
          )}
        </div>
      </div>
    </article>
  )
}
