---
// Section pré-footer ("Join the Journey") — bande commune (home, /character…).
// Label, titre et les 4 cartes sont éditables via Keystatic (singleton `prefooter`,
// lu par @data/prefooter). Chaque carte porte son lien (link), son style (primary)
// et un flag `isTrailer` : si vrai, le bouton ouvre la modale trailer globale avec
// l'ID vidéo global (settings.youtubevideoID) au lieu de suivre `link`.
// Les attributs additionnels (id, data-toc-section…) sont passés-plat sur la <section>
// — utile pour l'ancre de scroll-spy sur /character (id="join").
import BgImage from "@components/decor/BgImage.astro"
import CornerOrnament from "@components/decor/CornerOrnament.astro"
import Divider from "@components/decor/Divider.astro"
import DividerH from "@components/decor/DividerH.astro"
import CommunityCard from "@components/ui/CommunityCard.astro"
import { prefooter } from "@data/prefooter"
import { settings } from "@data/settings"

interface Props {
  class?: string
  [key: string]: unknown
}
const { class: className = "", ...rest } = Astro.props

const trailerId = settings.youtubevideoID ?? "vEUQxe2uM-w"
---

<!-- ─── Community / Join the Journey (pré-footer) ─────────────────────── -->
<!-- Bande image encadrée. Couches décoratives en pointer-events-none pour ne pas
     bloquer le clic des cartes (z-30/100). -->
<section class:list={["relative py-4 border-background-100 overflow-hidden", className]} {...rest}>
  <div
    class="relative mx-3 shadow-xl border-panel overflow-hidden border border-primary-300/30 px-4 lg:px-6 py-8 md:py-12 lg:py-28"
  >
    <div class="relative z-50 pointer-events-none hidden md:block">
      <Divider position="unset" class="top-1/2" />

      <div class="cercle z-10 absolute inset-x-0 mx-auto w-1/2 bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-20"></div>
      </div>

      <div class="cercle z-10 absolute inset-x-0 mx-auto w-full bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-10"></div>
      </div>
    </div>

    <div class="relative z-20 pointer-events-none hidden md:block">
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-50 bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-20"></div>
        <div
          class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"
        >
        </div>
        <div
          class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"
        >
        </div>
      </div>
    </div>

    <BgImage src="/images/bg1.jpeg" opacity={1} fixedBg position="object-center" class="z-10" />
    <div class="overlay-vignette2 backdrop-blur-sm z-10"></div>
    <div class="absolute w-full h-full inset-0 bg-black/70 z-10 pointer-events-none"></div>
    <CornerOrnament size={34} class="opacity-50 z-50 pointer-events-none" />

    <div class="relative z-30 text-center mb-7 md:mb-14">
      <p class="section-label mb-6 mx-auto mt-4">{prefooter.label}</p>
      <h2 class="title-section mb-8">{prefooter.title}</h2>
      <DividerH class="my-4 md:my-8 mx-auto max-w-lg" />
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2 md:gap-4 relative z-60">
      {
        prefooter.cards.map((card) => (
          <CommunityCard
            icon={card.icon}
            title={card.title}
            description={card.description}
            cta={card.cta}
            href={card.link ?? undefined}
            trailerId={card.isTrailer ? trailerId : undefined}
            primary={card.primary}
          />
        ))
      }
    </div>

    <Divider position="bottom" />
  </div>
</section>
