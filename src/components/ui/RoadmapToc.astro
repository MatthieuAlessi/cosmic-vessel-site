---
// Sommaire sticky du board roadmap : liste les catégories (+ compteur done/total)
// et sert de navigation avec scroll-spy. Remplace "Progress by craft".
import { roadmapCategories, slugify } from "@data/roadmapFeatures"

interface Props {
  class?: string
}
const { class: className = "" } = Astro.props

const items = roadmapCategories.map((c) => ({
  name: c.name,
  slug: slugify(c.name),
  total: c.features.length,
  done: c.features.filter((f) => f.status === "completed").length,
}))
---

<nav class:list={["roadmap-toc", className]} aria-label="Roadmap sections">
  <!-- <p class="font-ui text-2xs tracking-widest uppercase text-foreground-700 mb-5">On this page</p> -->
  <!-- Mobile : barre horizontale scrollable (chips) · Desktop : liste verticale -->
  <ul class="flex flex-row lg:flex-col gap-2 lg:gap-1 overflow-x-auto lg:overflow-visible [scrollbar-width:none]">
    {
      items.map((it) => (
        <li class="shrink-0">
          <a
            href={`#${it.slug}`}
            data-toc={it.slug}
            class="roadmap-toc__link group flex items-center gap-2 lg:gap-3 whitespace-nowrap rounded-md lg:rounded-none border border-white/10 lg:border-0 bg-background-300/50 lg:bg-transparent px-3 lg:px-0 py-1.5 lg:py-2 text-sm transition-colors"
          >
            <span class="roadmap-toc__bullet text-foreground-300 transition-colors">✦</span>
            <span class="roadmap-toc__label lg:flex-1 font-body text-xs text-white/40 transition-colors">
              {it.name}
            </span>
            <span class="font-ui text-2xs tracking-wide text-foreground-500">
              {it.done}/{it.total}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  // Scroll-spy : surligne l'entrée du sommaire correspondant à la section visible.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".roadmap-toc__link"))
  const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-toc-section]"))

  if (links.length && sections.length) {
    const setActive = (slug: string) => {
      links.forEach((l) => l.classList.toggle("is-active", l.dataset.toc === slug))
    }

    // Défilement animé au clic (enhancement progressif : le href reste le fallback).
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        const slug = link.dataset.toc
        const target = slug ? document.getElementById(slug) : null
        if (!target) return // pas de cible → on laisse le saut natif du href
        e.preventDefault() // on prend la main → pas de saut sec, pas de #hash dans l'URL
        target.scrollIntoView({ behavior: "smooth", block: "start" }) // respecte scroll-mt-28
        setActive(slug!) // surligne tout de suite, sans attendre le scroll-spy
      })
    })

    const observer = new IntersectionObserver(
      (entries) => {
        // Prend la section la plus haute actuellement intersectée
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
        if (visible[0]) setActive((visible[0].target as HTMLElement).dataset.tocSection || "")
      },
      // Zone de détection : bande haute de la fenêtre (sous le nav)
      { rootMargin: "-20% 0px -70% 0px", threshold: 0 },
    )

    sections.forEach((s) => observer.observe(s))
    setActive(sections[0].dataset.tocSection || "")
  }
</script>
