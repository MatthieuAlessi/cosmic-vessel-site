---
import ClassCard from '@components/ui/ClassCard.astro';
import SpellCard from '@components/ui/SpellCard.astro';
import DividerH from '@components/decor/DividerH.astro';
import BgImage from '@components/decor/BgImage.astro';
import GalaxyCanvas from '@components/decor/GalaxyCanvas.astro';
import Divider from '@components/decor/Divider.astro';
import { Icon } from 'astro-icon/components';
import CornerOrnament from '@components/decor/CornerOrnament.astro';

// Données placeholder des 4 voies (boucle interne — pas 1 composant par voie).
// `spells` = sorts principaux de la voie, assignés MANUELLEMENT ici (image +
// nom + mini-description). Remplace les `image` par tes propres visuels.
const voies = [
  {
    icon: '⚔',
    name: 'Voie 1',
    role: 'Lame cosmique',
    tags: ['Mêlée', 'Burst', 'Mobilité'],
    art: 'https://picsum.photos/seed/voie-1/800/1200',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Placeholder décrivant le fantasy de la première voie, son rôle en combat et ce qui la rend unique.',
    spells: [
      { image: 'https://picsum.photos/seed/spell-1a/200', name: 'Fendoir stellaire', description: 'Une entaille qui déchire l\'espace et inflige des dégâts de force en cône.' },
      { image: 'https://picsum.photos/seed/spell-1b/200', name: 'Ruée fulgurante', description: 'Se téléporte derrière la cible et frappe avant qu\'elle ne réagisse.' },
      { image: 'https://picsum.photos/seed/spell-1c/200', name: 'Impact gravitationnel', description: 'Écrase le sol : les ennemis proches sont projetés et étourdis.' },
      { image: 'https://picsum.photos/seed/spell-1d/200', name: 'Éclat rémanent', description: 'Chaque coup critique laisse une marque qui explose au coup suivant.' },
    ],
  },
  {
    icon: '✦',
    name: 'Voie 2',
    role: 'Tisseur d\'arcanes',
    tags: ['Distance', 'Contrôle', 'Invocation'],
    art: 'https://picsum.photos/seed/voie-2/800/1200',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Placeholder décrivant le fantasy de la deuxième voie, son rôle en combat et ce qui la rend unique.',
    spells: [
      { image: 'https://picsum.photos/seed/spell-2a/200', name: 'Trait arcanique', description: 'Un projectile d\'énergie pure qui traverse les boucliers magiques.' },
      { image: 'https://picsum.photos/seed/spell-2b/200', name: 'Prison de givre', description: 'Immobilise une zone dans une gangue de glace astrale.' },
      { image: 'https://picsum.photos/seed/spell-2c/200', name: 'Œil du néant', description: 'Invoque une sentinelle qui révèle et marque les ennemis dissimulés.' },
      { image: 'https://picsum.photos/seed/spell-2d/200', name: 'Rappel dimensionnel', description: 'Aspire les ennemis vers un point unique avant de les disperser.' },
    ],
  },
  {
    icon: '◈',
    name: 'Voie 3',
    role: 'Gardien des éclipses',
    tags: ['Soutien', 'Protection', 'Soin'],
    art: 'https://picsum.photos/seed/voie-3/800/1200',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Placeholder décrivant le fantasy de la troisième voie, son rôle en combat et ce qui la rend unique.',
    spells: [
      { image: 'https://picsum.photos/seed/spell-3a/200', name: 'Voile d\'éclipse', description: 'Érige une barrière qui absorbe les dégâts des alliés proches.' },
      { image: 'https://picsum.photos/seed/spell-3b/200', name: 'Lumière régénérante', description: 'Restaure les points de vie et purge une affliction.' },
      { image: 'https://picsum.photos/seed/spell-3c/200', name: 'Aube protectrice', description: 'Bénit le groupe : résistance accrue pendant quelques tours.' },
      { image: 'https://picsum.photos/seed/spell-3d/200', name: 'Répit lunaire', description: 'Zone de calme qui régénère les ressources des alliés.' },
    ],
  },
  {
    icon: '❂',
    name: 'Voie 4',
    role: 'Héraut du néant',
    tags: ['Hybride', 'Sacrifice', 'Channeling'],
    art: 'https://picsum.photos/seed/voie-4/800/1200',
    description:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Placeholder décrivant le fantasy de la quatrième voie, son rôle en combat et ce qui la rend unique.',
    spells: [
      { image: 'https://picsum.photos/seed/spell-4a/200', name: 'Pacte du vide', description: 'Sacrifie des points de vie pour libérer une vague d\'énergie corrompue.' },
      { image: 'https://picsum.photos/seed/spell-4b/200', name: 'Canalisation abyssale', description: 'Canalise un rayon dévastateur qui gagne en puissance dans le temps.' },
      { image: 'https://picsum.photos/seed/spell-4c/200', name: 'Dîme de sang', description: 'Draine la vie des ennemis touchés pour se soigner en retour.' },
      { image: 'https://picsum.photos/seed/spell-4d/200', name: 'Communion finale', description: 'Ultime : invoque une éclipse qui frappe tout le champ de bataille.' },
    ],
  },
];
---

<section class="bg-background-300 px-6 pt-24 pb-32 lg:pt-32 relative overflow-clip">

  <!-- Décor : cercles (identique à la section Classes home) -->
  <div class="relative z-1">
    <Divider position="unset" class="top-1/2" />
    <div class="cercle z-10 absolute inset-x-0 mx-auto w-1/2 bottom-0 translate-y-[50%]">
      <div class="aspect-square border border-width-1 border-primary-300 rounded-full opacity-30"></div>
    </div>
    <div class="cercle z-10 absolute inset-x-0 mx-auto w-full bottom-0 translate-y-[50%]">
      <div class="aspect-square border border-width-1 border-primary-300 rounded-full opacity-10"></div>
    </div>
  </div>

  <div class="relative z-20">
    <div class="cercle z-10 absolute inset-x-0 mx-auto w-50 bottom-0 translate-y-[50%]">
      <div class="aspect-square border border-width-1 border-primary-300 rounded-full opacity-20"></div>
      <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
      <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
    </div>
  </div>

  <div class="absolute inset-0 m-auto left-1/2 top-0 h-full border-l border-primary-300 opacity-30 z-1"></div>

  <BgImage
    src="/images/smoke1.jpeg"
    opacity={0.15}
    position="object-bottom"
    size="cover"
    class="mix-blend-hard-light z-1"
  />

  <div class="overlay-top z-1 opacity-90"></div>
  <div class="overlay-bottom z-1 opacity-90"></div>

  <BgImage
    src="/images/galaxy-pitch.jpeg"
    opacity={0.25}
    grayscale
    fixedBg
    position="object-center"
    size="80%"
    maskClass="mask-galaxy"
    class="z-10"
  />

  <GalaxyCanvas opacity={0.5} count={180} class="z-20" />

  <!-- En-tête -->
 

  <div class="max-w-7xl mx-auto relative z-20">

    <div class="text-center mb-12">
      <p class="title-label-ghost mb-8 mt-4 mx-auto">Game System</p>
      <h2 class="title-1 mb-6 text-primary-100">Game System</h2>

   <DividerH width="max-w-lg" class="my-8" />

     
   
    </div>

    <!-- Bande de chips (thumbs Swiper) + flèches de navigation -->
    <div class="flex items-stretch gap-4 mt-12 sticky-header p-2 bg-background-500/50  backdrop-blur-xs  border border-white/10  border-panel z-20 shadow-img-lift">
      <div class="voies-thumbs swiper flex-1 min-w-0">
        <div class="swiper-wrapper">
          {voies.map((voie) => (
            <div class="swiper-slide flex-1 w-auto group cursor-pointer">
              <div class="flex items-center gap-2 py-1 pr-2 pl-4 whitespace-nowrap border border-primary/30 transition-colors duration-300 group-[.swiper-slide-thumb-active]:border-primary/60 group-[.swiper-slide-thumb-active]:bg-primary/8 border-panel bg-background-300 ">

              <CornerOrnament size={34} corner="top-left" class="opacity-40" />
                <span class="w-full font-display text-base uppercase text-foreground-100 transition-colors duration-300 group-[.swiper-slide-thumb-active]:text-primary-100">
                  {voie.name}
                </span>
                <span class="w-12 h-9 shrink-0 overflow-hidden grayscale opacity-70 transition duration-300 group-[.swiper-slide-thumb-active]:grayscale-0 group-[.swiper-slide-thumb-active]:opacity-100">
                  <img src={voie.art} alt="" loading="lazy" class="w-full h-full object-cover" />
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="flex gap-2 shrink-0 items-center">
        <button type="button" class="voies-prev inline-flex items-center justify-center w-11 h-11 rounded-full border border-primary/40 text-primary-100 leading-none transition duration-300 hover:bg-primary/12 [&.swiper-button-disabled]:opacity-[0.35] [&.swiper-button-disabled]:cursor-default" aria-label="Voie précédente"><Icon name="lucide:chevron-left" class="w-5 h-5" /></button>
        <button type="button" class="voies-next inline-flex items-center justify-center w-11 h-11 rounded-full border border-primary/40 text-primary-100 leading-none transition duration-300 hover:bg-primary/12 [&.swiper-button-disabled]:opacity-[0.35] [&.swiper-button-disabled]:cursor-default" aria-label="Voie suivante"><Icon name="lucide:chevron-right" class="w-5 h-5" /></button>
      </div>
    </div>



  
    <div class="voies-main swiper ">
      <div class="swiper-wrapper">
        {voies.map((voie) => (
          <div class="swiper-slide">
            <div class="flex flex-col lg:flex-row gap-6 lg:gap-12 items-start pt-10">

              
              <div class="space-y-6 lg:grow-5 lg:basis-0 lg:min-w-0">
                <div>
                  <p class="section-label-ghost mb-4">{voie.role}</p>
                  <h3 class="title-2 text-primary-100">{voie.name}</h3>
                </div>
                {/* <div class="flex flex-wrap gap-2">
                  {voie.tags.map((tag) => (
                    <span class="badge badge--primary">{tag}</span>
                  ))}
                </div> */}
                <DividerH />
                <p class="text-foreground-300 font-body text-base leading-relaxed">
                  {voie.description}
                </p>
              </div>

           
              <div class="lg:grow-5 lg:basis-0 lg:min-w-0 w-full max-w-[350px] mx-auto">
                <ClassCard tilt name={voie.name} tagline={voie.role} art={voie.art} />
              </div>

 
              <div class="space-y-4 lg:grow-5 lg:basis-0 lg:min-w-0">
                <p class="font-display text-md uppercase  text-foreground-300  ">Sorts principaux</p>
                <div class="grid grid-cols-1   gap-2">
                  {voie.spells.map((spell) => (
                    <SpellCard image={spell.image} alt={spell.name} name={spell.name} description={spell.description} />
                  ))}
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>


  </div>
</section>

<script>
  import '../../scripts/voies-swiper.js';
</script>

 