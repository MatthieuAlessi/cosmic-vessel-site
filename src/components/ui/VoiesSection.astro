---
import ClassCard from '@components/ui/ClassCard.astro';
import SpellCard from '@components/ui/SpellCard.astro';
import DividerH from '@components/decor/DividerH.astro';
import BgImage from '@components/decor/BgImage.astro';
import GalaxyCanvas from '@components/decor/GalaxyCanvas.astro';
import Divider from '@components/decor/Divider.astro';
import { Icon } from 'astro-icon/components';
import CornerOrnament from '@components/decor/CornerOrnament.astro';
import { getCollection } from 'astro:content';

// Les 4 voies viennent de la collection `classes` (partagée avec la section
// Classes de la home). On reshape chaque entrée vers la forme attendue par le
// markup (name/role/art/description/spells) pour ne rien changer au rendu.
// `art` / `spell.image` : fallback picsum tant qu'aucune image n'est uploadée.
const voies = (await getCollection('classes')).map((entry, i) => ({
  name: entry.data.name,
  role: entry.data.tagline,
  description: entry.data.description,
  art: entry.data.image ?? `https://picsum.photos/seed/voie-${i + 1}/800/1200`,
  spells: (entry.data.spells ?? []).map((s, si) => ({
    image: s.image ?? `https://picsum.photos/seed/voie-${i + 1}-spell-${si}/200`,
    name: s.name,
    description: s.description,
  })),
}));

// Heading (label/title/text) passé par character.astro depuis le singleton
// `characterpage.sectionclass`.
interface Props {
  heading?: { label?: string; title?: string; text?: string };
}
const { heading } = Astro.props;
---

<section class="bg-background-300 px-2 lg:px-6 pt-12 pb-32 lg:pt-32 relative overflow-clip">

  <!-- Décor : cercles (identique à la section Classes home) -->
  <div class="relative z-1">
    <Divider position="unset" class="top-1/2" />
    <div class="cercle z-10 absolute inset-x-0 mx-auto w-1/2 bottom-0 translate-y-[50%]">
      <div class="aspect-square border border-width-1 border-primary-300 rounded-full opacity-30"></div>
    </div>
    <div class="cercle z-10 absolute inset-x-0 mx-auto w-full bottom-0 translate-y-[50%]">
      <div class="aspect-square border border-width-1 border-primary-300 rounded-full opacity-10"></div>
    </div>
  </div>

  <div class="relative z-20">
    <div class="cercle z-10 absolute inset-x-0 mx-auto w-50 bottom-0 translate-y-[50%]">
      <div class="aspect-square border border-width-1 border-primary-300 rounded-full opacity-20"></div>
      <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
      <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
    </div>
  </div>

  <div class="absolute inset-0 m-auto left-1/2 top-0 h-full border-l border-primary-300 opacity-30 z-1"></div>

  <BgImage
    src="/images/smoke1.jpeg"
    opacity={0.15}
    position="object-bottom"
    size="cover"
    class="mix-blend-hard-light z-1"
  />

  <div class="overlay-top z-1 opacity-90"></div>
  <div class="overlay-bottom z-1 opacity-90"></div>

  <BgImage
    src="/images/galaxy-pitch.jpeg"
    opacity={0.25}
    grayscale
    fixedBg
    position="object-center"
    size="80%"
    maskClass="mask-galaxy"
    class="z-10"
  />

  <GalaxyCanvas opacity={0.5} count={180} class="z-20" />

  <!-- En-tête -->


  <div class="max-w-7xl mx-auto relative z-20">

    <div class="text-center mb-12">
      <p class="title-label-ghost mb-8 mt-4 mx-auto">{heading?.label}</p>
      <h2 class="title-1 mb-6 text-primary-100">{heading?.title}</h2>

   <DividerH width="max-w-lg" class="my-8" />

             <p
          class="text-foreground-100 font-body text-sm lg:text-lg leading-relaxed max-w-xl mx-auto mb-8"
        >
          {heading?.text}
        </p>


    </div>

    <!-- Sélecteur de voies : 4 boutons (2×2 mobile, rangée en desktop). Sticky.
         Pilote le slider `.voies-main` (voir voies-swiper.js). -->
    <div class="sticky-header z-20 mt-8 lg:mt-12 flex items-stretch gap-3 p-2 bg-background-500/50 backdrop-blur-xs border border-white/10 border-panel shadow-img-lift">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 flex-1 min-w-0">
        {voies.map((voie, i) => (
          <button
            type="button"
            data-voie={i}
            aria-label={`Voir ${voie.name}`}
            class="voie-tab group flex items-center gap-2 py-1.5 pl-3 pr-2 cursor-pointer border border-primary/30 border-panel bg-background-300 transition-colors duration-300 [&.is-active]:border-primary/60 [&.is-active]:bg-primary/8"
          >
            <span class="flex-1 min-w-0 text-left font-display text-sm lg:text-base uppercase text-foreground-100 transition-colors group-[.is-active]:text-primary-100 truncate">
              {voie.name}
            </span>
            <span class="w-10 h-8 shrink-0 overflow-hidden rounded-sm grayscale opacity-70 transition duration-300 group-[.is-active]:grayscale-0 group-[.is-active]:opacity-100">
              <img src={voie.art} alt="" loading="lazy" class="w-full h-full object-cover" />
            </span>
          </button>
        ))}
      </div>

      <!-- Flèches — desktop : à côté du sélecteur (en mobile elles sont en bas) -->
      <div class="hidden lg:flex gap-2 shrink-0 items-center">
        <button
          type="button"
          class="voies-prev inline-flex items-center justify-center w-11 h-11 rounded-full border border-primary/40 text-primary-100 transition-colors duration-300 hover:bg-primary/10 [&.swiper-button-disabled]:opacity-30 [&.swiper-button-disabled]:cursor-default"
          aria-label="Voie précédente"
        >
          <Icon name="lucide:chevron-left" class="w-5 h-5" />
        </button>
        <button
          type="button"
          class="voies-next inline-flex items-center justify-center w-11 h-11 rounded-full border border-primary/40 text-primary-100 transition-colors duration-300 hover:bg-primary/10 [&.swiper-button-disabled]:opacity-30 [&.swiper-button-disabled]:cursor-default"
          aria-label="Voie suivante"
        >
          <Icon name="lucide:chevron-right" class="w-5 h-5" />
        </button>
      </div>
    </div>




    <div class="voies-main swiper ">
      <div class="swiper-wrapper">
        {voies.map((voie) => (
          <div class="swiper-slide">
            <div class="flex flex-col lg:flex-row gap-6 lg:gap-12 items-start pt-10">


              <div class="space-y-6 lg:grow-5 lg:basis-0 lg:min-w-0">
                <div>
                  <p class="section-label-ghost mb-4">{voie.role}</p>
                  <h3 class="title-2 text-primary-100">{voie.name}</h3>
                </div>
                <DividerH />
                <p class="text-foreground-300 font-body text-base leading-relaxed">
                  {voie.description}
                </p>
              </div>


              <div class="lg:grow-5 lg:basis-0 lg:min-w-0 w-full max-w-[190px] lg:max-w-[350px] mx-auto">
                <ClassCard tilt name={voie.name} tagline={voie.role} art={voie.art} />
              </div>


              <div class="space-y-4 lg:grow-5 lg:basis-0 lg:min-w-0 mt-4 lg:mt-0">
                <p class="font-display text-md uppercase  text-foreground-300  ">Sorts principaux</p>
                <div class="grid grid-cols-1   gap-2">
                  {voie.spells.map((spell) => (
                    <SpellCard image={spell.image} alt={spell.name} name={spell.name} description={spell.description} />
                  ))}
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Navigation du panneau : dots (toujours) + flèches (mobile only, desktop = à côté du sélecteur) -->
    <div class="mt-8 flex items-center justify-center gap-4">
      <button
        type="button"
        class="voies-prev lg:hidden inline-flex items-center justify-center w-10 h-10 shrink-0 rounded-full border border-primary/40 text-primary-100 transition-colors hover:bg-primary/10 [&.swiper-button-disabled]:opacity-30"
        aria-label="Voie précédente"
      >
        <Icon name="lucide:chevron-left" class="w-5 h-5" />
      </button>
      <div class="voies-dots flex items-center gap-2"></div>
      <button
        type="button"
        class="voies-next lg:hidden inline-flex items-center justify-center w-10 h-10 shrink-0 rounded-full border border-primary/40 text-primary-100 transition-colors hover:bg-primary/10 [&.swiper-button-disabled]:opacity-30"
        aria-label="Voie suivante"
      >
        <Icon name="lucide:chevron-right" class="w-5 h-5" />
      </button>
    </div>

  </div>
</section>

<script>
  import '../../scripts/voies-swiper.js';
</script>
