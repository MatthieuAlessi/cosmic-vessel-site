---
const year = new Date().getFullYear();

const links = [
  { href: '/', label: 'Accueil' },
  { href: '/character', label: 'Personnage' },
  { href: '/gallery', label: 'Galerie' },
  { href: '/blog', label: 'Actus' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="border-t border-white/8 bg-background">
  <div class="max-w-5xl mx-auto px-6 py-section-sm flex flex-col items-center gap-6 text-center">

    <a href="/" class="font-display text-sm tracking-display text-primary-100 uppercase">
      [MOD NAME]
    </a>

    <nav class="flex flex-wrap justify-center gap-6">
      {links.map(link => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </nav>

    <div>
      <p class="text-xs tracking-wider text-foreground-700 font-ui uppercase mb-3">
        Un mod non-officiel pour Baldur's Gate 3
      </p>
      <div class="divider-gold w-48 mx-auto opacity-30 mb-4"></div>
      <p class="text-2xs text-foreground-700 font-ui">
        © {year} Cosmic Vessel Team — Projet bénévole, non affilié à Larian Studios.
      </p>
    </div>

  </div>
</footer>
