---
interface Props {
  variant?: 'centered' | 'split' | 'fullscreen' | 'image-bg';
}

const { variant = 'centered' } = Astro.props;
---

{variant === 'centered' && (
  <section class="max-w-3xl mx-auto px-6 py-section-xl text-center space-y-6">
    <div class="flex justify-center">
      <slot name="badge" />
    </div>
    <h1 class="title-display">
      <slot name="title" />
    </h1>
    <p class="text-foreground-500 text-lg leading-relaxed max-w-xl mx-auto">
      <slot name="subtitle" />
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <slot name="cta" />
    </div>
  </section>
)}

{variant === 'split' && (
  <section class="max-w-5xl mx-auto px-6 py-section-lg grid grid-cols-1 gap-12 items-center lg:grid-cols-2">
    <div class="space-y-6">
      <slot name="badge" />
      <h1 class="title-display">
        <slot name="title" />
      </h1>
      <p class="text-foreground-500 text-lg leading-relaxed">
        <slot name="subtitle" />
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <slot name="cta" />
      </div>
    </div>
    <div class="relative">
      <slot name="visual" />
    </div>
  </section>
)}

{variant === 'fullscreen' && (
  <section class="relative min-h-screen flex flex-col items-center justify-center px-6 text-center overflow-hidden">
    <slot name="background" />
    <div class="overlay-bottom" />
    <div class="relative z-floating space-y-6 max-w-3xl">
      <div class="flex justify-center">
        <slot name="badge" />
      </div>
      <h1 class="title-display">
        <slot name="title" />
      </h1>
      <p class="text-foreground-500 text-lg leading-relaxed max-w-xl mx-auto">
        <slot name="subtitle" />
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-2">
        <slot name="cta" />
      </div>
    </div>
  </section>
)}

{variant === 'image-bg' && (
  <section class="relative px-6 py-section-xl overflow-hidden">
    <slot name="background" />
    <div class="vignette" />
    <div class="overlay-bottom" />
    <div class="relative z-floating max-w-2xl space-y-6">
      <slot name="badge" />
      <h1 class="title-display">
        <slot name="title" />
      </h1>
      <p class="text-foreground-300 text-lg leading-relaxed">
        <slot name="subtitle" />
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <slot name="cta" />
      </div>
    </div>
  </section>
)}
