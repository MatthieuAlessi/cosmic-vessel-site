---
import { Icon } from "astro-icon/components"
import CornerOrnament from "@components/decor/CornerOrnament.astro"
import Button from "@components/ui/Button.astro"

interface Props {
  /** Icône de la carte (nom Phosphor). */
  icon: string
  title: string
  description: string
  /** Libellé du bouton. */
  cta: string
  /** Lien du bouton (externe). Ignoré si `trailerId` est fourni. */
  href?: string
  /** Si fourni, le bouton ouvre la modale trailer globale au lieu de naviguer. */
  trailerId?: string
  /** Bouton en style primaire (plein) plutôt qu'outline. */
  primary?: boolean
  /** Taille du bouton (transmise à Button). */
  size?: "xs" | "sm" | "md" | "lg"
  class?: string
}
const {
  icon,
  title,
  description,
  cta,
  href,
  trailerId,
  primary = false,
  size = "md",
  class: className = "",
} = Astro.props

const variant = primary ? "primary" : "outline"
---

<div
  class:list={[
    "group relative flex flex-col items-center text-center gap-4 p-4 md:p-6 border border-primary-700/30 backdrop-blur-xs border-panel shadow-img-lift/35 bg-background-100/10",
    className,
  ]}
>
  <CornerOrnament size={28} corner="top-left" class="opacity-40" />
  <CornerOrnament size={28} corner="bottom-right" class="opacity-40" />

  <span class="flex items-center justify-center w-11 aspect-square rounded-full bg-primary/10 text-primary-100">
    <Icon name={icon} class="w-5 h-5" />
  </span>

  <div>
    <h3 class="font-display text-sm tracking-wide uppercase text-primary-100 mb-1.5">{title}</h3>
    <p class="text-foreground-500 font-body text-xs leading-relaxed">{description}</p>
  </div>

  {
    trailerId ? (
      <Button variant={variant} size={size} class="mt-auto" data-trailer-open data-video-id={trailerId}>
        {cta}
      </Button>
    ) : (
      <Button variant={variant} size={size} href={href} target="_blank" class="mt-auto">
        {cta}
      </Button>
    )
  }
</div>
