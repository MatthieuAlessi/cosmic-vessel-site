---
import { Icon } from "astro-icon/components"
import CornerOrnament from "@components/decor/CornerOrnament.astro"

interface Props {
  /** Icône de la carte (nom Phosphor). */
  icon: string
  title: string
  description: string
  /** Libellé du bouton. */
  cta: string
  /** Lien du bouton (externe). Ignoré si `trailerId` est fourni. */
  href?: string
  /** Si fourni, le bouton ouvre la modale trailer globale au lieu de naviguer. */
  trailerId?: string
  /** Bouton en style primaire (plein) plutôt qu'outline. */
  primary?: boolean
  class?: string
}
const { icon, title, description, cta, href, trailerId, primary = false, class: className = "" } =
  Astro.props

const btnClass = ["btn py-2 px-5 text-sm mt-auto", primary ? "btn--primary" : "btn--outline"]
---

<div
  class:list={[
    "group relative flex flex-col items-center text-center gap-4 p-6 border border-primary-700/30 backdrop-blur-xs border-panel shadow-img-lift/35 bg-background-100/10",
    className,
  ]}
>
  <CornerOrnament size={28} corner="top-left" class="opacity-40" />
  <CornerOrnament size={28} corner="bottom-right" class="opacity-40" />

  <span class="flex items-center justify-center w-11 aspect-square rounded-full bg-primary/10 text-primary-100">
    <Icon name={icon} class="w-5 h-5" />
  </span>

  <div>
    <h3 class="font-display text-sm tracking-wide uppercase text-primary-100 mb-1.5">{title}</h3>
    <p class="text-foreground-500 font-body text-xs leading-relaxed">{description}</p>
  </div>

  {
    trailerId ? (
      <button type="button" data-trailer-open data-video-id={trailerId} class:list={btnClass}>
        {cta}
      </button>
    ) : (
      <a href={href} target="_blank" rel="noopener noreferrer" class:list={btnClass}>
        {cta}
      </a>
    )
  }
</div>
