---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title={`${post.data.title} — [MOD NAME]`}
  description={post.data.excerpt}
>
  <Nav />

  <main class="pt-32 pb-24">
    <div class="max-w-2xl mx-auto px-6">

      <!-- Back -->
      <a href="/blog" class="inline-flex items-center gap-2 text-foreground-500 hover:text-primary font-ui text-xs tracking-wider uppercase transition-colors duration-300 mb-12">
        ← Retour aux actus
      </a>

      <!-- Header article -->
      <header class="mb-12">
        <div class="flex gap-3 mb-4">
          {post.data.tags.map(tag => (
            <span class="font-ui text-2xs tracking-wider uppercase text-primary border border-primary-700 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
        <h1 class="font-display text-4xl md:text-5xl tracking-wider text-primary-100 uppercase leading-tight mb-6">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-4 text-xs font-ui tracking-wider text-foreground-700 uppercase">
          <span>{formatDate(post.data.date)}</span>
          <span>·</span>
          <span>{post.data.author}</span>
        </div>
      </header>

      <div class="divider-gold mb-12"></div>

      <!-- Contenu -->
      <article class="prose max-w-none">
        <Content />
      </article>

      <div class="divider-gold mt-16 mb-10"></div>

      <!-- Nav article -->
      <a href="/blog" class="btn btn--ghost">← Tous les articles</a>
    </div>
  </main>

  <Footer />
</Layout>
