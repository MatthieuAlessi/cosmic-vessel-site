---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Actus & Devlogs — [MOD NAME]">
  <Nav />

  <main class="pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <header class="mb-20">
        <p class="section-label">Journal de développement</p>
        <h1 class="font-display text-6xl tracking-widest text-primary-100 uppercase">Actus</h1>
      </header>

      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="card-cinematic group flex gap-6 p-0 overflow-hidden block">
            <div class="img-overlay w-48 shrink-0">
              <img src={post.data.cover ?? `https://picsum.photos/seed/${post.id}/400/300`} alt={post.data.title} class="w-full h-full object-cover" />
            </div>
            <div class="p-6 flex flex-col justify-center">
              <div class="flex gap-3 mb-3">
                {post.data.tags.slice(0, 3).map(tag => (
                  <span class="font-ui text-2xs tracking-wider uppercase text-primary-700">{tag}</span>
                ))}
              </div>
              <h2 class="font-display text-xl tracking-wide text-primary-100 uppercase mb-2 group-hover:text-primary transition-colors duration-300">
                {post.data.title}
              </h2>
              <p class="text-foreground-500 font-body mb-4 line-clamp-2">{post.data.excerpt}</p>
              <div class="flex items-center gap-4 text-2xs font-ui tracking-wider text-foreground-700 uppercase">
                <span>{formatDate(post.data.date)}</span>
                <span>·</span>
                <span>{post.data.author}</span>
              </div>
            </div>
          </a>
        ))}

        {posts.length === 0 && (
          <div class="card-cinematic p-16 text-center">
            <p class="font-display text-primary-700 tracking-wider uppercase">Aucun article pour le moment</p>
            <p class="text-foreground-700 font-body mt-3 text-sm">Revenez bientôt pour les premiers devlogs.</p>
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
