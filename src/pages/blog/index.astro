---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/ui/Nav.astro';
import Footer from '@components/ui/Footer.astro';
import Card from '@components/ui/Card.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Actus & Devlogs — [MOD NAME]">
  <Nav />

  <main class="pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <header class="mb-12">
        <p class="title-label text-center lg:text-left mb-6 lg:mb-8 mx-auto lg:mx-0">Dev journal</p>
        <h1 class="title-hero">News</h1>
      </header>

      <div class="flex flex-col gap-6">
        {posts.map(post => (
          <Card variant="horizontal" cta="Read more" href={`/blog/${post.id}`}>
            <img
              slot="image"
              src={post.data.cover ?? `https://picsum.photos/seed/${post.id}/400/300`}
              alt={post.data.title}
              class="img-cover"
              loading="lazy"
            />
            <Fragment slot="badge">
              {post.data.tags.slice(0, 3).map(tag => (
                <span class="badge badge--primary">{tag}</span>
              ))}
            </Fragment>
            <Fragment slot="title">{post.data.title}</Fragment>
            <Fragment slot="excerpt">{post.data.excerpt}</Fragment>
            <Fragment slot="meta">
              <span>{formatDate(post.data.date)}</span>
              <span>·</span>
              <span>{post.data.author}</span>
            </Fragment>
          </Card>
        ))}

        {posts.length === 0 && (
          <div class="card-cinematic p-16 text-center">
            <p class="font-display text-primary-700 tracking-wider uppercase">Aucun article pour le moment</p>
            <p class="text-foreground-700 font-body mt-3 text-sm">Revenez bientôt pour les premiers devlogs.</p>
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
