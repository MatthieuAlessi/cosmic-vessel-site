      <div class="grid lg:grid-cols-[230px_1fr] gap-10 lg:gap-16">
        <aside class="hidden lg:block">
          <RoadmapToc class="sticky-header" />
        </aside>
        <div>
          <RoadmapBoard />
        </div>
      </div>
    </div>
