---
import Layout from "@layouts/Layout.astro"
import Nav from "@components/ui/Nav.astro"
import Footer from "@components/ui/Footer.astro"
import BgImage from "@components/decor/BgImage.astro"
import CornerOrnament from "@components/decor/CornerOrnament.astro"
import { Icon } from "astro-icon/components"

// ─── Liens communauté (placeholder, à remplacer) ──────────────────────────
const discordUrl = "https://discord.gg/your-invite"
const kofiUrl = "https://ko-fi.com/your-page"
const twitterUrl = "https://x.com/your-handle"
const youtubeUrl = "https://youtube.com/@your-channel"

const socials = [
  { icon: "ph:discord-logo", href: discordUrl, label: "Discord" },
  { icon: "ph:x-logo", href: twitterUrl, label: "X" },
  { icon: "ph:youtube-logo", href: youtubeUrl, label: "YouTube" },
  { icon: "ph:coffee", href: kofiUrl, label: "Ko-fi" },
]

// "Join the team" retiré : les candidatures passent par le Google Form (settings.joinformUrl).
const subjects = ["General question", "Press & media", "Bug report", "Other"]

const fieldClass =
  "w-full bg-background-300/50 border-panel border border-white/10 focus:border-primary px-2 py-2 font-body text-white/60 text-sm transition-all duration-300 placeholder:text-foreground-700"
const fieldClassSelect =
  "w-full bg-background-300/50 border-panel border border-white/10 focus:border-primary py-4 px-2 font-body text-white/60 text-sm transition-all duration-300 placeholder:text-foreground-700"
const labelClass = "block font-ui text-sm text-foreground-100 mb-1"
---

<Layout
  title="Contact — Cosmic Vessel"
  description="Get in touch with the team behind the Cosmic Vessel mod for Baldur's Gate 3."
>
  <Nav />

  <main class="pt-18 pb-6">
    <div class="px-3 mx-auto  lg:px-3">
      <!-- Bloc image encadrée : titre en bas-gauche + formulaire flottant à droite -->
      <div class="relative lg:min-h-160 p-4 sm:p-8 lg:p-12">
        <!-- Image de fond encadrée (border + corner, comme les bandes de la home).
             Masquée en mobile : le titre passe alors sur le fond sombre du body →
             meilleure lisibilité (le formulaire a déjà son propre fond solide). -->
        <div
          class="hidden lg:block absolute inset-0 shadow-xl border-panel overflow-hidden border border-primary-300/30"
        >
          <BgImage src="/images/bg1.jpeg" opacity={1} position="object-center" class="z-0" />
          <div class="overlay-vignette2 z-0"></div>
          <CornerOrnament size={34} class="opacity-50 z-10" />
        </div>

        <!-- Contenu par-dessus l'image -->
        <div class="relative z-10 grid lg:grid-cols-7 gap-8 lg:gap-6 items-end">
          <!-- Titre (bas-gauche) -->
          <div class="lg:pb-8 lg:col-span-4">
            <p class="section-label mb-4">Contact</p>
            <h1 class="title-section">Get in touch</h1>
            <p class="text-foreground-300 font-body text-lg mt-6 max-w-sm">
              Questions, feedback, or want to join the team? We're listening.
            </p>
          </div>

          <!-- Formulaire flottant (dark, gardé tel quel) -->
          <div
            class="relative lg:col-span-3 border-panel border border-primary-500/20 bg-background-500 shadow-xl p-6 sm:p-8 lg:p-14"
          >
            <CornerOrnament size={28} corner="top-left" class="opacity-40" />
            <CornerOrnament size={28} corner="bottom-right" class="opacity-40" />

            <h2 class="font-display text-xl tracking-wide uppercase text-primary-100 mb-4">
              Send us a message
            </h2>
            <!-- <p class="text-foreground-500 font-body text-sm mb-8">
              We usually reply within a few days — on Discord for anything quicker.
            </p> -->

            <form class="flex flex-col gap-4" method="POST" data-netlify="true" name="contact">
              <input type="hidden" name="form-name" value="contact" />

              <!-- Nom / Email -->
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="name" class={labelClass}>Full name</label>
                  <input type="text" id="name" name="name" required class={fieldClass} />
                </div>
                <div>
                  <label for="email" class={labelClass}>Email</label>
                  <input type="email" id="email" name="email" required class={fieldClass} />
                </div>
              </div>

              <!-- Sujet -->
              <div>
                <label for="subject" class={labelClass}>Subject</label>
                <select id="subject" name="subject" class:list={[fieldClassSelect, "select-dark"]}>
                  {subjects.map((s) => <option value={s}>{s}</option>)}
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class={labelClass}>Message</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="4"
                  class={`${fieldClass} resize-y`}></textarea>
              </div>

              <button type="submit" class="btn btn--primary w-full py-3 mt-2">
                <Icon name="ph:paper-plane-tilt" class="w-5 h-5" />
                Send message
              </button>
            </form>

            <!-- Réseaux -->
            <div class="flex items-center gap-3 mt-8 pt-6 border-t border-primary-700/20">
              {
                socials.map((s) => (
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.label}
                    class="flex items-center justify-center w-10 aspect-square rounded-full border border-primary-700/30 text-foreground-500 hover:text-primary-100 hover:border-primary-500/60 transition-colors"
                  >
                    <Icon name={s.icon} class="w-5 h-5" />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* La liste déroulante du <select> est rendue par l'OS : seuls le fond et la
     couleur des <option> sont stylables de façon fiable (le reste du chrome ne
     l'est pas). On force donc un fond sombre cohérent avec le thème. */
  select option {
    background-color: var(--color-background-500);
    color: var(--color-foreground-100);
  }
</style>
