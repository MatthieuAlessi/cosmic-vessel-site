  <!-- ─── 4. Les 4 Voies — sélecteur (statique, TODO toggle JS) ──────────── -->
  <VoiesSection />

  <!-- ─── 5. CTA — teaser galerie + suivre le projet ────────────────────── -->
  <section class="bg-background-500 py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Teaser galerie -->
      <div>
        <p class="section-label mb-6">Gallery</p>
        <div class="grid grid-cols-3 gap-3">
          {[1, 2, 3, 4, 5, 6].map((i) => (
            <div class="img-overlay">
              <img src={`https://picsum.photos/seed/char-gal-${i}/400/400`} alt="" class="w-full h-full object-cover aspect-square" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="mt-8">
          <Button variant="outline" href="/gallery">Explore the gallery</Button>
        </div>
      </div>

      <!-- Suivre le projet -->
      <div class="text-center lg:text-left">
        <p class="section-label mb-6">Follow the project</p>
        <h2 class="title-1 mb-6 text-primary-100">[Join the journey]</h2>
        <p class="text-foreground-500 font-body text-base leading-relaxed mb-10 max-w-md mx-auto lg:mx-0">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Placeholder pour inciter à suivre le développement du mod.
        </p>
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          <Button href="/blog">Follow Development</Button>
          <Button variant="outline" href="/contact">Join the Discord</Button>
        </div>
        <StarMarks class="justify-center lg:justify-start mt-12" />
