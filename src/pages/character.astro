---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import BgImage from '@components/BgImage.astro';
import DividerGeo from '@components/DividerGeo.astro';
import StarMarks from '@components/StarMarks.astro';
import ArchFrame from '@components/ArchFrame.astro';
import VoiesSection from '@components/VoiesSection.astro';
import Button from '@components/ui/Button.astro';
import SplitSection from '@components/ui/SplitSection.astro';
---

<Layout
  title="[CHARACTER NAME] — Origin Character | [MOD NAME]"
  description="Discover the origin character — lore, unique class and exclusive paths."
>
  <Nav />

  <!-- ─── 1. Hero — portrait arche plein écran ──────────────────────────── -->
  <section class="section-hero overflow-hidden lg:h-[50vh] h-[70vh] bg-background relative">

    <BgImage
      src="/images/galaxy-pitch2.jpeg"
      opacity={0.45}
      position="object-center"
      fixedBg
      size="cover"
      maskClass="  "
    />





    <div class="cache--gradient2"></div>

    <div class="relative z-10 h-full flex flex-col items-center xl:justify-end  justify-center text-left px-6 py-24 gap-10 max-w-7xl mx-auto">
 
      <div class="space-y-4 text-center">
        <p class="section-label">Origin Character</p>
        <h1 class="title-hero">[CHARACTER NAME]</h1>
        <p class="title-4 text-white tracking-display">[Class] · [Origin] · [Arcane]</p>
      </div>
    </div>

    <div class="line absolute bottom-0 left-0 w-full"></div>
  </section>








 



  <!-- ─── Lore — texte/image alterné ──────────────────────────────────── -->
  <section class="relative bg-background-500 py-24 lg:py-32 overflow-clip">




    <BgImage
      src="/images/bg1.jpeg"
      opacity={0.05}
      position="object-center"
       
      fixedBg
      size="cover"
      class="   "
    /> 




    
<div class="overlay-top"></div>
 
 

    <div class="relative z-10 max-w-7xl mx-auto px-6 flex flex-col gap-24 lg:gap-24">

      <!-- Bloc 1 : texte gauche / image droite -->
      <div class="flex items-start lg:flex-row-reverse flex-col  gap-8 lg:gap-24 xl:gap-24 ">

        <div class="py-5 space-y-5 lg:grow-4 lg:basis-0 lg:min-w-0 lg:sticky-header">
         
             <p class="section-label mb-4">Lore</p>
      <h2 class="title-1 mb-6">[Lore Heading]</h2>

          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            The Red Moon is a nightmare. The servants of the Vessel are fully awakened, the beasts grow more ravenous, and the children of the void become visible. In this nightmare, the world reveals the eldritch truths it had long kept hidden.
          </p>
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            As a result, everything turns darker, and the character begins to see the world as it would if they had gathered enough insight. By following the call, you usher in the coming of the Red Moon.
          </p>
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            Whether it brings salvation or ruin, no one can say. The cosmos is a towering, labyrinthine cathedral — and you are the key turning in its lock.
          </p>
          <StarMarks class="pt-2" />
        </div>

        <div class="relative lg:grow-4 lg:basis-0 outline-1 outline-primary-700/50 outline-offset-6 lg:sticky-header shadow-img-lift">
          <img src="https://picsum.photos/seed/lore-1/640/800" alt="" class="w-full aspect-square object-cover" loading="lazy" />
        </div>

      </div>

      <!-- Bloc 2 : image gauche / texte droite -->
       <div class="flex items-start lg:flex-row flex-col  gap-8 lg:gap-24 xl:gap-36 ">

        <div class="py-5 space-y-5 lg:grow-4 lg:basis-0 lg:min-w-0 lg:sticky-header">
          <p class="section-label">Chapter II — The Ashen Blood</p>
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            Eventually, the old sanctuary was founded — but it was brought low by an affliction known as the Ashen Blood, a slow and merciless corruption that spread through every living thing it touched.
          </p>
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            Along with the physical transformation comes a mental unraveling. At first the afflicted assume that all they do not know is hostile, and they strike on sight — until nothing of who they were remains.
          </p>
          <StarMarks class="pt-2" />
        </div>

        <div class="relative lg:grow-4 lg:basis-0 outline-1 outline-primary-700/50 outline-offset-6 lg:sticky-header shadow-img-lift">
          <img src="https://picsum.photos/seed/lore-2/640/800" alt="" class="w-full aspect-square object-cover" loading="lazy" />
        </div>

      </div>

    </div>

   
      <div class="line absolute bottom-0 left-0 w-full"></div>

       <div class="overlay-bottom opacity-80"></div> 

  </section>








  <!-- ─── 1b. Flavour éditorial ───────────────────────────────────────── -->
  <section class="relative bg-background-700 pt-32 pb-24 overflow-hidden">

    <!-- Overlay lignes de grille (12 colonnes, motif décoratif) -->
    <div class="absolute inset-0 grid grid-cols-12 grid-rows-[auto_auto_6rem_auto_4rem_auto_auto_6rem_auto] pointer-events-none z-10" aria-hidden="true">
      <div class="col-start-1  row-start-1 row-end-10"></div>
      <div class="col-start-2  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-3  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-4  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-5  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-6  row-start-1 row-end-10 border-primary-700/10"></div>
      <div class="col-start-7  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-8  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-9  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-10 row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-11 row-start-1 row-end-10"></div>
      <div class="col-start-12 row-start-1 row-end-10"></div>
      <div class="col-start-1 col-end-13 row-start-5 border-t border-primary-700/10"></div>
      <div class="col-start-1 col-end-13 row-start-8 border-t border-primary-700/10"></div>
    </div>

    <BgImage
      src="/images/bg1.jpeg"
      opacity={0.5}
      position="object-center"
      fixedBg
      size="cover"
      maskClass="mask-galaxy--img"
      class="blur-sm"
    />


<div class="char v2 mask-galaxy--img">  
    <img src="/images/char_placeholder.png" alt="">
  </div>

    <div class="cache--gradient2"></div>

    <div class="relative z-1">
      <div class="line absolute top-1/2 left-0 w-full"></div>
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-1/2 bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-30"></div>
        <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
        <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
      </div>
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-full bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-10"></div>
        <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
        <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
      </div>
    </div>

    <div class="overlay-top z-2 opacity-90"></div>

    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute left-0 top-0 aspect-square w-1/2 -translate-x-1/2"
        style="background: radial-gradient(ellipse at center, rgba(201,147,58,0.2) 0%, transparent 70%); filter: blur(40px);"></div>
      <div class="absolute right-0 top-1/3 aspect-square w-1/2 translate-x-1/2"
        style="background: radial-gradient(ellipse at center, rgba(201,147,58,0.2) 0%, transparent 70%); filter: blur(40px);"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-1/2"
        style="background: radial-gradient(ellipse 60% 100% at 50% 100%, rgba(201,147,58,0.15) 0%, transparent 70%); filter: blur(30px);"></div>
    </div>

    <div class="relative z-20">
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-50 bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-20"></div>
        <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
        <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
      </div>
    </div>

    <div class="absolute inset-0 m-auto left-1/2 top-0 h-full border-l border-primary-300 opacity-20 z-1"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-40 mt-4">

      <div class="absolute top-0 right-6 text-right">
        <p class="font-display text-xs text-primary tracking-widest">CHAPITRE II</p>
        <p class="font-display text-xs text-foreground-500 tracking-widest">L'ÉVEIL</p>
      </div>
      <StarMarks class="absolute top-1 left-6" />

      <!-- Composition character : Born of / the void / A soul / unbound -->
      <div class="editorial-grid grid grid-cols-12 grid-rows-[auto_auto_6rem_auto_4rem_auto_auto_auto_auto] gap-4 pt-16">

        <h2 class="editorial-word col-span-7 col-start-1 row-start-1 self-start whitespace-nowrap">Born of</h2>
        <h2 class="editorial-word col-span-8 col-start-1 row-start-2 self-start whitespace-nowrap text-primary-300">the void</h2>

        <div class="col-span-4 col-start-9 row-start-4 mt-8">
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            Forged in the collapse of a dying star, the vessel carries a fragment of the cosmos within. Its origin is neither mortal nor divine — something older. No chain of fate holds what was never meant to exist. Every step rewrites a destiny that was never written.
          </p>
        </div>

        <h2 class="editorial-word col-start-1 col-end-13 text-right row-start-7 self-start whitespace-nowrap">A soul</h2>
        <h2 class="editorial-word col-start-1 col-end-13 text-right row-start-8 self-start text-primary-300">unbound</h2>

        <div class="col-span-4 col-start-1 row-start-6 row-end-8 mt-4">
          <p class="text-foreground-500 font-body text-xs uppercase leading-relaxed tracking-wide">
            No chain of fate holds what was never meant to exist. Every step rewrites a destiny that was never written. Forged in the collapse of a dying star, the vessel carries a fragment of the cosmos within. Its origin is neither mortal nor divine — something older.
          </p>
        </div>

      </div>

      <StarMarks class="justify-center mt-8" />
    </div>

    <div class="line absolute top-0 left-0 w-full"></div>
  </section>





<div class="relative   h-[60vh] min-h-[300px]">

    <BgImage
      src="/images/bg1.jpeg"
      opacity={1}  
      fixedBg
      position="object-center"
       
      
      class="z-10"
    />
 
</div>


