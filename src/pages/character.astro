---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/ui/Nav.astro';
import Footer from '@components/ui/Footer.astro';
import BgImage from '@components/decor/BgImage.astro';
import DividerH from '@components/decor/DividerH.astro';
import DividerV from '@components/decor/DividerV.astro';
import Divider from '@components/decor/Divider.astro';
import StarMarks from '@components/decor/StarMarks.astro';
import VoiesSection from '@components/ui/VoiesSection.astro';
import SectionPrefooter from '@components/ui/SectionPrefooter.astro';
import ChapterNav from '@components/ui/ChapterNav.astro';
import Button from '@components/ui/Button.astro';
import { characterData } from '@data/character';

const { hero, section1, section2, sectionclass, section3 } = characterData;

// ─── Chapitres (sous-nav sticky + scroll-spy) ─────────────────────────────
// Chaque slug doit matcher un id + data-toc-section sur la section correspondante.
const chapters = [
  { label: "Lore", slug: "lore" },
  { label: "The Paths", slug: "paths" },
  { label: "The Vessel", slug: "vessel" },
  { label: "Join", slug: "join" },
];
---

<Layout
  title="[CHARACTER NAME] — Origin Character | [MOD NAME]"
  description="Discover the origin character — lore, unique class and exclusive paths."
>
  <Nav />

  <!-- ─── Hero — showcase perso : texte à gauche, render 3D détouré à droite ── -->
  <section class="relative overflow-hidden bg-background-700 pt-24 pb-12 lg:pt-40 lg:pb-20">
    <!-- Fond atmosphérique, calé à droite (derrière le render) + masque vignette galaxy -->
    <BgImage
      src="/images/galaxy-pitch2.jpeg"
      opacity={0.55}
      position="object-right"
      size="cover"
      maskClass="mask-galaxy--img"
    />
    

    <!-- Voile dégradé gauche→droite pour la lisibilité du texte (reste sombre jusqu'à ~50%) -->
    <div
      class="absolute inset-0 z-1 bg-linear-to-r from-background-700 from-15% via-background-700/70 via-50% to-transparent"
    >
    </div>

    <!-- Contenu texte à gauche, centré verticalement -->
    <div class="relative z-30 w-full max-w-7xl mx-auto px-4 lg:px-6">
      <div class="max-w-2xl">
        <p class="section-label mb-6">{hero?.label}</p>
        <h1 class="title-section mb-0 text-balance">{hero?.title}</h1>

        <!-- Filet horizontal + point à gauche (cf. inspi) -->
     <DividerH width="max-w-lg" class="my-8 ml-1" />

        <p class="text-foreground-300 font-body text-md leading-relaxed max-w-sm">
          {hero?.description}
        </p>

        <div class="flex flex-wrap items-center gap-4 mt-10">
          <Button href="/gallery">View the gallery</Button>
          <Button variant="outline" href="/blog">Follow the dev</Button>
        </div>
      </div>
    </div>

    <Divider position="bottom" />
  </section>

  <!-- ─── Sous-nav de chapitres (sticky + scroll-spy) ─────────────────────── -->
  <!-- hideOnSection="paths" : la barre se replie quand VoiesSection (son propre
       sélecteur sticky) est active, pour éviter deux barres sticky en conflit. -->
  <ChapterNav items={chapters} hideOnSection="paths" />





 



  <!-- ─── Lore — texte/image alterné ──────────────────────────────────── -->
  <section
    id="lore"
    data-toc-section="lore"
    class="relative bg-background-500 py-16 lg:py-32 overflow-clip scroll-mt-32"
  >




    <BgImage
      src="/images/bg1.jpeg"
      opacity={0.05}
      position="object-center"
       
      fixedBg
      size="cover"
      class="   "
    /> 




    
<div class="overlay-top"></div>
 
 

    <div class="relative z-10 max-w-7xl mx-auto px-4 lg:px-6 flex flex-col gap-6 md:gap-12 lg:gap-20">

      <!-- Bloc 1 : image à gauche / texte à droite (style Lore de index) -->
      <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-8 items-center relative">
        <div class="col-span-1 lg:col-span-4">
          <div
            class="relative outline-1 outline-primary-700/50 outline-offset-6 shadow-img-lift border-panel overflow-hidden"
          >
            <img
              src={section1?.block1?.image ?? "https://picsum.photos/seed/lore-1/640/800"}
              alt=""
              class="w-full aspect-3/2 object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <div class="col-span-1 lg:col-span-2 hidden lg:block">
          <DividerV dotTop={true} dotBottom={true} position="center" class="z-1 hidden lg:block" />
        </div>

        <div class="col-span-1 lg:col-span-4 lg:py-10">
          <p class="section-label mb-4 lg:mb-6 mx-0 lg:mx-0">{section1?.block1?.label}</p>
          <h3 class="title-3 text-foreground-100 mb-4">{section1?.block1?.title}</h3>
          <p class="text-foreground-500 font-body text-base leading-relaxed">
            {section1?.block1?.text}
          </p>
          <StarMarks class="pt-6" />
        </div>
      </div>

         <div class="  w-full mx-auto border-t border-primary-300/10 my-8"></div>

      <!-- Bloc 2 : texte à gauche / image à droite (alternance) -->
      <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-8 items-center relative   ">
        <div class="col-span-1 lg:col-span-4 lg:py-10 lg:order-1 order-2">
          <p class="section-label  mb-4 lg:mb-6 mx-0 lg:mx-0">{section1?.block2?.label}</p>
          <h3 class="title-3 text-foreground-100 mb-4">{section1?.block2?.title}</h3>
          <p class="text-foreground-500 font-body text-base leading-relaxed">
            {section1?.block2?.text}
          </p>
          <StarMarks class="pt-6" />
        </div>

        <div class="col-span-1 lg:col-span-2 lg:order-2 order-3 hidden lg:block">
          <DividerV dotTop={true} dotBottom={true} position="center" class="z-1 hidden lg:block" />
        </div>

        <div class="col-span-1 lg:col-span-4 lg:order-3 order-1">
          <div
            class="relative outline-1 outline-primary-700/50 outline-offset-6 shadow-img-lift border-panel overflow-hidden"
          >
            <img
              src={section1?.block2?.image ?? "https://picsum.photos/seed/lore-2/640/800"}
              alt=""
              class="w-full aspect-3/2 object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>

    </div>

   
      <Divider position="bottom" />

       <div class="overlay-bottom opacity-80"></div> 

  </section>








  <!-- ─── Story — lore narratif (blocs de texte répétables via le CMS) ──── -->
  <section
    id="story"
    class="relative bg-background-700 py-16 lg:py-28 overflow-clip scroll-mt-32"
  >
    <BgImage
      src="/images/bg1.jpeg"
      opacity={0.05}
      position="object-center"
      fixedBg
      size="cover"
    />
    <div class="overlay-top"></div>
    <div class="overlay-bottom"></div>
    <Divider position="top" opacity={0.6} />

    <div class="relative z-10 max-w-3xl mx-auto px-4 lg:px-6">
      {(section2?.label || section2?.title) && (
        <div class="text-center mb-12 lg:mb-16">
          <p class="section-label mb-4 lg:mb-6 mx-auto">{section2?.label}</p>
          <h2 class="title-1 text-primary-100">{section2?.title}</h2>
          <DividerH width="max-w-lg" class="my-8 mx-auto" />
        </div>
      )}

      <div class="flex flex-col gap-10 lg:gap-14">
        {section2?.blocks?.map((b) => (
          <div>
            {b.title && <h3 class="title-3 text-foreground-100 mb-4">{b.title}</h3>}
            <div class="space-y-4 text-foreground-500 font-body text-base leading-relaxed">
              {b.text?.split("\n\n").map((para) => (para.trim() ? <p>{para.trim()}</p> : null))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <Divider position="bottom" />
  </section>

  <!-- ─── Les 4 Voies — sélecteur (section propre à character) ───────────── -->
  <div id="paths" data-toc-section="paths" class="scroll-mt-32">
    <VoiesSection heading={sectionclass} />
  </div>

  <!-- ─── 1b. Flavour éditorial ───────────────────────────────────────── -->
  <section
    id="vessel"
    data-toc-section="vessel"
    class="relative bg-background-700 py-16 lg:pt-32 lg:pb-24 overflow-hidden scroll-mt-32 border-b border-primary-700/30"
  >

 <Divider position="top" />

    <!-- Overlay lignes de grille (12 colonnes, motif décoratif) -->
    <div class="absolute inset-0 grid grid-cols-12 grid-rows-[auto_auto_6rem_auto_4rem_auto_auto_6rem_auto] pointer-events-none z-10" aria-hidden="true">
      <div class="col-start-1  row-start-1 row-end-10"></div>
      <div class="col-start-2  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-3  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-4  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-5  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-6  row-start-1 row-end-10 border-primary-700/10"></div>
      <div class="col-start-7  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-8  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-9  row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-10 row-start-1 row-end-10 border-r border-primary-700/10"></div>
      <div class="col-start-11 row-start-1 row-end-10"></div>
      <div class="col-start-12 row-start-1 row-end-10"></div>
      <div class="col-start-1 col-end-13 row-start-5 border-t border-primary-700/10"></div>
      <div class="col-start-1 col-end-13 row-start-8 border-t border-primary-700/10"></div>
    </div>

    <BgImage
      src="/images/bg1.jpeg"
      opacity={0.5}
      position="object-center"
      fixedBg
      size="cover"
      maskClass="mask-galaxy--img"
      class="blur-sm"
    />


<!-- <div class="char v2 mask-galaxy--img">  
    <img src="/images/char_placeholder.png" alt="">
  </div> -->

    <div class="cache--gradient2"></div>

    <div class="relative z-1">
      <Divider position="unset" class="top-1/2" />
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-1/2 bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-30"></div>
        <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
        <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
      </div>
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-full bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-10"></div>
        <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
        <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
      </div>
    </div>

    <div class="overlay-top z-2 opacity-90"></div>

    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute left-0 top-0 aspect-square w-1/2 -translate-x-1/2"
        style="background: radial-gradient(ellipse at center, rgba(201,147,58,0.2) 0%, transparent 70%); filter: blur(40px);"></div>
      <div class="absolute right-0 top-1/3 aspect-square w-1/2 translate-x-1/2"
        style="background: radial-gradient(ellipse at center, rgba(201,147,58,0.2) 0%, transparent 70%); filter: blur(40px);"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-1/2"
        style="background: radial-gradient(ellipse 60% 100% at 50% 100%, rgba(201,147,58,0.15) 0%, transparent 70%); filter: blur(30px);"></div>
    </div>

    <div class="relative z-20">
      <div class="cercle z-10 absolute inset-x-0 mx-auto w-50 bottom-0 translate-y-[50%]">
        <div class="aspect-square border border-primary-300 rounded-full opacity-20"></div>
        <div class="dot absolute top-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-black border-primary-700 border translate-y-[-40%]"></div>
        <div class="dot absolute bottom-0 inset-x-0 m-auto w-1.5 aspect-square rounded-full bg-primary translate-y-[40%]"></div>
      </div>
    </div>

    <div class="absolute inset-0 m-auto left-1/2 top-0 h-full border-l border-primary-300 opacity-20 z-1"></div>

    <div class="max-w-7xl mx-auto px-4 lg:px-6 relative z-40 mt-4">

      <div class="absolute top-0 right-6 text-right">
        <p class="font-display text-xs text-primary tracking-widest">{section3?.label}</p>
        <p class="font-display text-xs text-foreground-500 tracking-widest">VOYAGE COSMIQUE</p>
      </div>
      <StarMarks class="absolute top-1 left-6" />

      <!-- Composition : Beyond / the stars / A vessel / cosmic (reprise de index) -->
      <div class="editorial-grid flex flex-col   lg:grid lg:grid-cols-12 lg:grid-rows-[auto_auto_6rem_auto_4rem_auto_auto_6rem_auto] gap-3 lg:gap-4 pt-16">

        <h2 class="editorial-word lg:col-span-7 lg:col-start-1 lg:row-start-1 self-start">Beyond</h2>
        <h2 class="editorial-word lg:col-span-7 lg:col-start-5 lg:row-start-2 lg:whitespace-nowrap text-primary-300 mb-3 lg:mb-0">
          the stars
        </h2>

        <div class="lg:col-span-4 lg:col-start-8 lg:row-start-3 lg:mt-8 mb-3 lg:mb-0">
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            {section3?.text1}
          </p>
        </div>

        <h2 class="editorial-word lg:col-span-8 lg:col-start-1 lg:row-start-6 self-start lg:whitespace-nowrap">
          A vessel
        </h2>
        <h2 class="editorial-word lg:col-span-9 lg:col-start-1 lg:row-start-7 self-start text-primary-300 mb-3 lg:mb-0">
          cosmic
        </h2>

        <div class="lg:col-span-4 lg:col-start-10 lg:row-start-6 lg:mt-4">
          <p class="text-foreground-500 font-body text-xs uppercase leading-relaxed tracking-wide">
            {section3?.text2}
          </p>
        </div>

        <div class="lg:col-span-4 lg:col-start-1 lg:row-start-8 lg:mt-8">
          <p class="text-foreground-500 font-body text-sm leading-relaxed">
            {section3?.text3}
          </p>
        </div>

      </div>

      <StarMarks class="justify-center mt-8" />
    </div>
<div class="overlay-bottom"></div>
    <!-- <Divider position="top" /> -->
  </section>





  <!-- ─── Image seule encadrée (bande image de index) ───────────────────── -->
  <!-- <div class="relative h-[60vh] min-h-75">
    <div
      class="absolute inset-x-3 shadow-xl top-0 bottom-0 border-panel overflow-hidden border border-primary-300/30"
    >
      <BgImage src="/images/bg1.jpeg" opacity={1} fixedBg position="object-center" class="z-10" />
      <div class="overlay-vignette z-10"></div>
      <CornerOrnament size={34} class="opacity-50 z-50" />
    </div>
  </div> -->

  <!-- ─── Community / Join the Journey (pré-footer, composant partagé) ──── -->
  <SectionPrefooter id="join" data-toc-section="join" class="scroll-mt-32" />

  <Footer />
</Layout>
