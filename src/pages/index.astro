            {teamSection?.text2}
          </p>

          <!-- Cluster d'avatars → funnel vers /team -->
          <a href="/team" class="group inline-flex flex-col items-center lg:items-start gap-4 mb-0">
            <ul class="flex items-center -space-x-3">
              {teamAvatars.map((m) => (
                <li>
                  <img
                    src={m.avatar}
                    alt={m.name}
                    class="w-12 h-12 rounded-full object-cover border-2 border-background-500 ring-1 ring-primary-700/40 transition-transform group-hover:-translate-y-0.5"
                  />
                </li>
              ))}
              {teamTotal > teamAvatars.length && (
                <li
                  class="w-12 h-12 rounded-full border-2 border-background-500 bg-primary/15 text-primary-100 flex items-center justify-center font-display text-sm"
                >
                  +{teamTotal - teamAvatars.length}
                </li>
              )}
            </ul>
       
          </a>

  

          <DividerH width="max-w-md" class="my-6 lg:my-10 mx-auto lg:mx-0  " />

          <!-- CTA recrutement (bouton Discord retiré — déjà présent dans la section Join the Journey) -->
          <p class="text-foreground-300 font-body mb-6">
            We're always looking for new talent to join the journey.
          </p>
          <div class="flex flex-wrap   justify-center lg:justify-start gap-2 md:gap-4">
            <Button href={joinTeamUrl} target="_blank">
              <Icon name="ph:users-three" class="w-5 h-5" />
              Join the team
            </Button>
           <Button variant="outline" href="/team">Discover the team</Button>
          </div>
        </div>
      </div>

  


    </div>
  </div>






  <Divider position="bottom" />
</section>

 

<!-- ─── News (grid x4, Card article) ───────────────────────────────────── -->
{
  recentPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 md:px-0 py-12 md:py-20 border-t border-background-100">


<div class="flex justify-between items-end mb-6">
    <div class="text-left relative z-20">
      <p class="section-label mb-4 lg:mb-6">{news?.label}</p>
      <h2 class="title-1   text-primary-100">{news?.title}</h2>
       
    </div>

  
    <div>
       <Button variant="outline" href="/gallery">See all</Button>
    </div>
</div>


      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2 md:gap-4">
        {recentPosts.map((post) => (
          <Card variant="article" cta="Read more" href={`/blog/${post.id}`}>
            <img
              slot="image"
              src={post.data.cover ?? `https://picsum.photos/seed/${post.id}/800/450`}
              alt={post.data.title}
              class="img-cover"
              loading="lazy"
            />
            <Fragment slot="badge">
              {post.data.tags.slice(0, 2).map((tag) => (
                <span class="badge badge--primary">{tag}</span>
              ))}
            </Fragment>
            <Fragment slot="title">{post.data.title}</Fragment>
            <Fragment slot="excerpt">{post.data.excerpt}</Fragment>
            <Fragment slot="meta">
              {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </Fragment>
          </Card>
        ))}
      </div>
    </section>
  )
}

<!-- ─── Community / Join the Journey (pré-footer, composant partagé) ──── -->
<SectionPrefooter />

<Footer />
</Layout>

