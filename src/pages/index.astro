---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/ui/Nav.astro';
import Footer from '@components/ui/Footer.astro';
import BgImage from '@components/decor/BgImage.astro';
import DividerGeo from '@components/decor/DividerGeo.astro';
import CornerOrnament from '@components/decor/CornerOrnament.astro';
import StarMarks from '@components/decor/StarMarks.astro';
import GalaxyCanvas from '@components/decor/GalaxyCanvas.astro';
import CircleSmall from '@components/decor/CircleSmall.astro';
import Divider from '@components/decor/Divider.astro';
import DividerV from '@components/decor/DividerV.astro';
import Button from '@components/ui/Button.astro';
import Card from '@components/ui/Card.astro';
import ClassTextPanel from '@components/ui/ClassTextPanel.astro';
import RoadmapCard from '@components/ui/RoadmapCard.astro';
import StatCard from '@components/ui/StatCard.astro';
import { getCollection } from 'astro:content';

const roadmapEntries = await getCollection('roadmap');
const roadmap = roadmapEntries.sort((a, b) => a.data.order - b.data.order);

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

