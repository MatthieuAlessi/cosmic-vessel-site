            <Fragment slot="excerpt">Short description.</Fragment>
          </Card>
        </div>
      </div>

      <!-- Col 3 : textes -->
      <div id="class-texts" class="flex-1 min-w-0 self-end">
        
         
        
        <ClassTextPanel index={0} active title="Class 1" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. A class designed to fully embody the character's cosmic nature and martial heritage." subclasses={[
          { name: 'Subclass A', description: 'Focused on combat and mastery of ancient weapons.' },
          { name: 'Subclass B', description: 'Focused on arcane magic and shadow manipulation.' },
        ]} />
        <ClassTextPanel index={1} title="Class 2" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. A second class with its own unique abilities and cosmic playstyle." subclasses={[
          { name: 'Subclass A', description: 'Focused on summoning and cosmic pacts.' },
          { name: 'Subclass B', description: 'Focused on stealth and temporal manipulation.' },
        ]} />
        <ClassTextPanel index={2} title="Class 3" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. A third class built around narrative versatility and adaptive power." subclasses={[
          { name: 'Subclass A', description: 'Focused on healing and protecting allies.' },
          { name: 'Subclass B', description: 'Focused on raw destruction and cosmic channeling.' },
        ]} />
      </div>

    </div>
  </section>

  <style is:global>
    #class-cards .class-card article {
      transition-delay: 0s;
    }
    #class-cards .class-card.is-hovered article {
      transform: translateY(-0.5rem);
      filter: drop-shadow(0 0 30px rgba(173, 141, 89, 0.15));
      transition-delay: 0.5s;
    }
  </style>

  <script>
    const tabs = document.querySelectorAll('#class-tabs .class-tab');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const i = (tab as HTMLElement).dataset.index;

        tabs.forEach(t => t.classList.remove('is-active'));
        document.querySelectorAll('#class-cards .class-card').forEach(p => {
          p.classList.remove('is-active');
          p.classList.remove('is-hovered');
        });
        document.querySelectorAll('#class-texts .class-text').forEach(p => p.classList.remove('is-active'));

        tab.classList.add('is-active');
        document.querySelector(`#class-cards .class-card[data-index="${i}"]`)?.classList.add('is-active');
        document.querySelector(`#class-texts .class-text[data-index="${i}"]`)?.classList.add('is-active');
        document.querySelector(`#class-cards .class-card[data-index="${i}"]`)?.classList.add('is-hovered');
      });
    });
  </script>










