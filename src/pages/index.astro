    #class-cards .class-card.is-hovered article {
      transform: translateY(-0.5rem);
      filter: drop-shadow(0 0 30px rgba(173, 141, 89, 0.15));
      transition-delay: 0.5s;
    }
  </style>

  <script>
    const tabs = document.querySelectorAll('#class-tabs .class-tab');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const i = (tab as HTMLElement).dataset.index;

        tabs.forEach(t => t.classList.remove('is-active'));
        document.querySelectorAll('#class-cards .class-card').forEach(p => {
          p.classList.remove('is-active');
          p.classList.remove('is-hovered');
        });
        document.querySelectorAll('#class-texts .class-text').forEach(p => p.classList.remove('is-active'));

        tab.classList.add('is-active');
        document.querySelector(`#class-cards .class-card[data-index="${i}"]`)?.classList.add('is-active');
        document.querySelector(`#class-texts .class-text[data-index="${i}"]`)?.classList.add('is-active');
        document.querySelector(`#class-cards .class-card[data-index="${i}"]`)?.classList.add('is-hovered');
      });
    });
  </script>








