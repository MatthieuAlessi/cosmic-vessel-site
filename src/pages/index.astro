<Layout title="[MOD NAME] — Origin Mod for Baldur's Gate 3">
  <Nav />

  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <section class="section-hero overflow-hidden lg:h-screen h-[50vh] bg-background">

   
        <BgImage
