import SectionPrefooter from "@components/ui/SectionPrefooter.astro"
import { Icon } from "astro-icon/components"
import { getCollection } from "astro:content"
import { settings, trailerVideoId } from "@data/settings"

import { homepageData } from "@data/homepage";


const { discordUrl, kofiUrl } = settings

 const { hero, section1, section2, sectioncharacter, sectionclass, gallery, roadmap, team: teamSection, news } = homepageData;

const joinTeamUrl = settings.joinformUrl

 
 

const subclasses = await getCollection("classes")

const recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4)

// ─── Équipe (teaser home) ──────────────────────────────────────────────────
// 8 avatars : les vrais membres de la collection, complétés par des placeholders
// pravatar.cc aléatoires. teamTotal / teamRoles restent des placeholders.
const team = await getCollection("team")
const teamAvatars = Array.from({ length: 8 }, (_, i) => ({
  name: team[i]?.data.name ?? "Team Member",
  avatar: team[i]?.data.avatar ?? `https://i.pravatar.cc/200?img=${Math.ceil(Math.random() * 70)}`,
}))
const teamTotal = 30
 
