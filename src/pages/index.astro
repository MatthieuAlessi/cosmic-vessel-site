---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import BgImage from '@components/BgImage.astro';
import DividerGeo from '@components/DividerGeo.astro';
import CornerOrnament from '@components/CornerOrnament.astro';
import GalaxyCanvas from '@components/GalaxyCanvas.astro';
import Button from '@components/ui/Button.astro';
import Card from '@components/ui/Card.astro';
import ClassTextPanel from '@components/ClassTextPanel.astro';
import RoadmapCard from '@components/RoadmapCard.astro';
import { getCollection } from 'astro:content';

const roadmapEntries = await getCollection('roadmap');
const roadmap = roadmapEntries.sort((a, b) => a.data.order - b.data.order);

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

