---
import Layout from "@layouts/Layout.astro"
import Nav from "@components/ui/Nav.astro"
import Footer from "@components/ui/Footer.astro"
import DividerH from "@components/decor/DividerH.astro"
import PageHero from "@components/ui/PageHero.astro"
import TeamMemberCard from "@components/ui/TeamMemberCard.astro"
import TeamOpenRoleCard from "@components/ui/TeamOpenRoleCard.astro"
import { Icon } from "astro-icon/components"
import { getCollection } from "astro:content"
import { departments } from "@data/team"
import { settings } from "@data/settings"
import { teamPageData } from "@data/teampage"

const { hero } = teamPageData

const members = await getCollection("team")

// ─── Liens (placeholder, à remplacer) ──────────────────────────────────────
const discordUrl = "https://discord.gg/your-invite"
// Candidatures : formulaire Google externe (Keystatic `joinformUrl`), pas /contact.
const joinTeamUrl = settings.joinformUrl

const PLACEHOLDERS_PER_DEPT = 8 // cartes placeholder pour visualiser une catégorie remplie

// Membres réels par catégorie, complétés par des placeholders jusqu'à 8.
// Avatars placeholder : visages variés via pravatar.cc (index déterministe).
const roster = departments.map((dept, di) => {
  const real = members
    .filter((m) => m.data.department === dept.id)
    .map((m) => ({ name: m.data.name, role: m.data.role, avatar: m.data.avatar, socials: m.data.socials, placeholder: false }))

  const missing = Math.max(0, PLACEHOLDERS_PER_DEPT - real.length)
  const placeholders = Array.from({ length: missing }, (_, i) => ({
    name: "Team Member",
    // Rôle varié pioché dans dept.sampleRoles (éditable dans @data/team) ;
    // repli sur le nom du département si la liste est vide.
    role: dept.sampleRoles[i % dept.sampleRoles.length] ?? dept.name,
    avatar: `https://i.pravatar.cc/200?img=${((di * PLACEHOLDERS_PER_DEPT + i) % 70) + 1}`,
    socials: { linkedin: "placeholder", website: "https://example.com", twitter: "@placeholder" },
    placeholder: true,
  }))

  return { ...dept, people: [...real, ...placeholders] }
})
---

<Layout
  title="The Team — Cosmic Vessel"
  description="Meet the volunteers bringing the Cosmic Vessel mod for Baldur's Gate 3 to life."
>
  <Nav />

  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <PageHero label={hero?.label} title={hero?.title} description={hero?.description} />

  <!-- ─── Roster par catégorie ──────────────────────────────────────────── -->
  <section class="relative bg-background-500 py-12 lg:py-24 overflow-hidden">
    <div class="overlay-top"></div>

    <div class="max-w-7xl mx-auto px-4 lg:px-6 relative z-10 flex flex-col gap-12 lg:gap-20">
      {
        roster.map((dept) => (
          <section>
            <header class="flex items-center gap-3 mb-6">
              {/* <Icon name={dept.icon} class="w-5 h-5 text-primary-300 shrink-0" /> */}
              <h2 class="font-display   title-3 uppercase text-foreground-100 shrink-0">
                {dept.name}
              </h2>
              <span class="h-px flex-1 bg-white/10" />
            </header>

            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2 lg:gap-4">
              {dept.people.map((p) => (
                <TeamMemberCard
                  name={p.name}
                  role={p.role}
                  avatar={p.avatar}
                  socials={p.socials}
                  placeholder={p.placeholder}
                />
              ))}

              {/* Cartes des rôles recherchés (recrutement) */}
              {dept.openRoles.map((role) => (
                <TeamOpenRoleCard role={role} href={joinTeamUrl} target="_blank" />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>

  <!-- ─── CTA recrutement ───────────────────────────────────────────────── -->
  <section class="relative bg-background-700 py-16 lg:py-24 overflow-hidden border-t border-background-100">
    <div class="relative z-10 max-w-2xl mx-auto px-6 text-center">
      <p class="section-label mb-8 mx-auto">Get involved</p>
      <h2 class="title-1 mb-6 text-primary-100">Join the journey</h2>
      <p class="text-foreground-300 font-body mb-10">
        Don't see your exact role? The Cosmic Vessel is a volunteer project — if you're passionate
        and skilled, we'd love to hear from you.
      </p>
      <DividerH width="max-w-md" class="my-10 mx-auto" />
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href={joinTeamUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary py-3 px-8 text-sm"
        >
          <Icon name="ph:users-three" class="w-5 h-5" />
          Join the team
        </a>
        <a
          href={discordUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline py-3 px-8 text-sm"
        >
          <Icon name="ph:discord-logo" class="w-5 h-5" />
          Discord
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
